# =============================================================================
# SOCMINT Suspect Profiling System — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Application runtime ----------------------------------------------------
# Environment name: development | staging | production
APP_ENV=development
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Host the FastAPI server binds to inside the container
API_HOST=0.0.0.0
# Port the FastAPI server listens on
API_PORT=8000

# --- PostgreSQL -------------------------------------------------------------
# Password for the PostgreSQL `socmint` user
POSTGRES_PASSWORD=changeme_in_prod

# --- Neo4j ------------------------------------------------------------------
# Password for the Neo4j `neo4j` user (identity graph store)
NEO4J_PASSWORD=changeme_in_prod

# --- MinIO ------------------------------------------------------------------
# MinIO root username (object storage for preserved evidence)
MINIO_USER=socmint
# MinIO root password
MINIO_PASSWORD=changeme_in_prod

# --- Connection strings (consumed by services) ------------------------------
# Redis broker + result backend URL for Celery
REDIS_URL=redis://redis:6379/0
# Full SQLAlchemy / psycopg2 connection URL for PostgreSQL
DATABASE_URL=postgresql://socmint:${POSTGRES_PASSWORD}@postgres:5432/socmint
# Neo4j Bolt protocol URI
NEO4J_URI=bolt://neo4j:7687
# MinIO endpoint (host:port, no scheme)
MINIO_ENDPOINT=minio:9000

# =============================================================================
# TOOL API KEYS & CREDENTIALS  —  ALL OPTIONAL
# Every adapter degrades gracefully to 'unavailable' when its key is unset.
# Fill any slot, then apply with:
#   docker compose restart worker_python worker_beat api
# =============================================================================

# --- Breach / leaked-data lookups (email & username seeds) ------------------
# KEYLESS adapters already cover breach data with NO key required:
#   xposedornot (breach analytics) | hudsonrock (infostealer) | proxynova (combo).
# The slots below add OPTIONAL extra providers. h8mail also runs without a key.
# H8mail breach-correlation API key
H8MAIL_API_KEY=
# HaveIBeenPwned API key (paid since 2019) used to supplement H8mail
HIBP_API_KEY=
# Extra breach providers — provide a key, then ask to wire/enable its adapter:
DEHASHED_EMAIL=
DEHASHED_API_KEY=
INTELX_API_KEY=
LEAKLOOKUP_API_KEY=
SNUSBASE_API_KEY=

# --- Email / identity enrichment (provide key to activate) ------------------
# Hunter.io (25 free searches/mo): domain→emails, email verification
HUNTERIO_API_KEY=
# EmailRep.io: email reputation + linked social profiles
EMAILREP_API_KEY=
# FullContact: person enrichment from email
FULLCONTACT_API_KEY=

# --- Phone intelligence (provide key to activate) ---------------------------
# numverify (~250 free/mo): carrier, line type, region
NUMVERIFY_API_KEY=
# AbstractAPI phone validation (free tier)
ABSTRACTAPI_PHONE_KEY=

# --- Domain / IP / infrastructure intelligence (provide key to activate) ----
# VirusTotal (free tier): domain/IP/passive-DNS intel
VIRUSTOTAL_API_KEY=
# SecurityTrails (free tier): historical DNS / subdomains
SECURITYTRAILS_API_KEY=
# Shodan (free tier): host/service exposure
SHODAN_API_KEY=
# Censys (free tier): host/certificate/banner data — uses HTTP Basic (API ID + Secret)
CENSYS_API_ID=
CENSYS_API_SECRET=
# DNS Dumpster (free tier): subdomain/DNS recon
DNSDUMPSTER_API_KEY=

# --- AI geolocation (photo → lat/lon, called only when EXIF GPS absent) -----
# Picarta AI photo geolocation (free: 10 calls, paid: $59.90/mo for 100)
PICARTA_API_KEY=
# Master toggle — 0 to disable (default), 1 to enable
AI_GEOLOCATION_ENABLED=0

# --- Reddit (authenticated API for user profile enrichment) -----------------
# Reddit OAuth2 application credentials (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- GitHub (free, high ROI) ------------------------------------------------
# Personal access token (https://github.com/settings/tokens) — no scopes needed.
# Powers github_api profile enrichment + GitHound; raises rate limit to 5000/hr.
GITHUB_TOKEN=

# --- Platform session tokens ------------------------------------------------
# Instagram session ID cookie used by Toutatis (set at deploy time)
INSTAGRAM_SESSION_ID=your_session_token_here
# Path inside the container to the GHunt Google auth cookies file
GHUNT_COOKIES_PATH=/tools/python/ghunt/cookies.json
# Telegram API credentials (https://my.telegram.org/apps) for telegram_intel.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telethon user session — mint once via worker_python/telegram_session_login.py
TELEGRAM_SESSION=

# --- Proxy ------------------------------------------------------------------
# Tor SOCKS5 proxy used by dorking / rate-sensitive tools (mandatory for Tier 3)
TOR_PROXY=socks5://127.0.0.1:9050
