# =============================================================================
# SOCMINT Suspect Profiling System — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Application runtime ----------------------------------------------------
# Environment name: development | staging | production
APP_ENV=development
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Host the FastAPI server binds to inside the container
API_HOST=0.0.0.0
# Port the FastAPI server listens on
API_PORT=8000

# --- PostgreSQL -------------------------------------------------------------
# Password for the PostgreSQL `socmint` user
POSTGRES_PASSWORD=changeme_in_prod

# --- Neo4j ------------------------------------------------------------------
# Password for the Neo4j `neo4j` user (identity graph store)
NEO4J_PASSWORD=changeme_in_prod

# --- MinIO ------------------------------------------------------------------
# MinIO root username (object storage for preserved evidence)
MINIO_USER=socmint
# MinIO root password
MINIO_PASSWORD=changeme_in_prod

# --- Connection strings (consumed by services) ------------------------------
# Redis broker + result backend URL for Celery
REDIS_URL=redis://redis:6379/0
# Full SQLAlchemy / psycopg2 connection URL for PostgreSQL
DATABASE_URL=postgresql://socmint:${POSTGRES_PASSWORD}@postgres:5432/socmint
# Neo4j Bolt protocol URI
NEO4J_URI=bolt://neo4j:7687
# MinIO endpoint (host:port, no scheme)
MINIO_ENDPOINT=minio:9000

# --- Tool API keys (free tiers) ---------------------------------------------
# H8mail breach-correlation API key (free tier)
H8MAIL_API_KEY=your_free_key_here
# HaveIBeenPwned API key (free tier) used to supplement H8mail
HIBP_API_KEY=your_free_key_here

# --- Platform session tokens ------------------------------------------------
# Instagram session ID cookie used by Toutatis (set at deploy time)
INSTAGRAM_SESSION_ID=your_session_token_here
# Path inside the container to the GHunt Google auth cookies file
GHUNT_COOKIES_PATH=/tools/python/ghunt/cookies.json

# --- Proxy ------------------------------------------------------------------
# Tor SOCKS5 proxy used by dorking / rate-sensitive tools (mandatory for Tier 3)
TOR_PROXY=socks5://127.0.0.1:9050
